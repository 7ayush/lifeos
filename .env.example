# LifeOS — Docker Compose Environment Variables
# Copy to .env:  cp .env.example .env

# --- Cloudflare Tunnel ---
# Create a tunnel at: Cloudflare Zero Trust → Networks → Tunnels
# Copy the tunnel token and paste it here:
CLOUDFLARE_TUNNEL_TOKEN=

# --- CORS ---
# Must include your Cloudflare Pages frontend URL:
# CORS_ORIGINS=https://lifeos.pages.dev,https://yourdomain.com
