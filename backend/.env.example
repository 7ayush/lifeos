# LifeOS Backend — Environment Variables Template
# Copy this to .env and fill in your values:  cp .env.example .env

# --- Required ---
JWT_SECRET_KEY=                  # A strong random secret for signing JWTs
GOOGLE_CLIENT_ID=                # Google OAuth client ID from console.cloud.google.com
DATABASE_URL=                    # PostgreSQL: postgresql://user:pass@host:5432/dbname

# --- Optional (defaults shown) ---
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# RATE_LIMIT_STORAGE_URI=memory://     # Use redis://host:6379 for multi-worker production
# MAX_REQUEST_BODY_BYTES=1048576       # 1 MB
# BYPASS_GOOGLE_AUTH=false             # Only used in test suite
